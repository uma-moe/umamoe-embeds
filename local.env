# Local Docker Compose defaults for umamoe-embeds.
#
# This file is intentionally non-secret. It is used by:
#   ../umamoe-backend/compose.local.yml

# Container bind address. The compose file publishes this as 127.0.0.1:3008.
UMAMOE_EMBEDS_BIND=0.0.0.0:8080

# Public URL used for canonical links and generated Open Graph image URLs.
UMAMOE_PUBLIC_BASE_URL=http://127.0.0.1:3008

# Angular shell origin. Inside Docker this must reach the host ng serve process.
UMAMOE_FRONTEND_ORIGIN=http://host.docker.internal:4200

# Public static assets. These are safe to use directly; resources stay internal below.
UMAMOE_ASSET_BASE_URL=https://uma.moe/assets

# Backend API for profile/club metadata.
UMAMOE_API_BASE_URL=http://umamoe-backend:3001

# Search API for database query previews.
UMAMOE_SEARCH_BASE_URL=http://umamoe-search:3202

# Internal Docker resources API for factors, skills, affinity, and race mappings.
# Do not point this at the public /resources route; it requires browser proof.
UMAMOE_RESOURCES_BASE_URL=http://umamoe-resources:3204/resources

# Query param that forces embed HTML in a normal browser.
UMAMOE_EMBEDS_DEBUG_QUERY_KEY=__embed

# Comma-separated user-agent fragments that receive embed HTML instead of the SPA shell.
UMAMOE_EMBEDS_BOT_USER_AGENT_TOKENS=Discordbot,Twitterbot,Slackbot,facebookexternalhit,Facebot,LinkedInBot,WhatsApp,TelegramBot,SkypeUriPreview,Pinterestbot,redditbot,Tumblr,Viber,Line,Embedly,Iframely,vkShare,Mastodon,Misskey,Bluesky
